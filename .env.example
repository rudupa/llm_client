# ── Provider selection (set in claude_api_example.py: PROVIDER = "ollama"|"gemini"|"claude") ──

# Anthropic Claude — https://console.anthropic.com/  (paid, no free tier)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini — https://aistudio.google.com/app/apikey  (free tier available)
GEMINI_API_KEY=your_gemini_key_here

# Ollama — no key needed, runs locally (install from https://ollama.com)
# Run:  ollama pull llama3.2
